<body style="margin:0;padding:0;background-color:#F0EBE1;">
  <div style="display:none;max-height:0;overflow:hidden;opacity:0;mso-hide:all;">Your Afams order {{params.order_number}} is confirmed — we're getting it ready for you.</div>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;background-color:#F0EBE1;">
    <tr>
