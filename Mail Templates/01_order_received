                </tr>
                <tr>
                  <td style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#6B7C6B;border-bottom:1px solid #E0D9CE;">Order REF</td>
                  <td align="right" style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#1B4332;font-weight:bold;border-bottom:1px solid #E0D9CE;">{{params.order_ref}}</td>
                </tr>
                <tr>
                  <td style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#6B7C6B;border-bottom:1px solid #E0D9CE;">Product</td>
                  <td align="right" style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#1B4332;font-weight:bold;border-bottom:1px solid #E0D9CE;">{{params.product_name}}</td>
                </tr>
                <tr>
                  <td style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#6B7C6B;border-bottom:1px solid #E0D9CE;">Quantity</td>
                  <td align="right" style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#1B4332;font-weight:bold;border-bottom:1px solid #E0D9CE;">{{params.quantity}}</td>
                </tr>
                <tr>
                  <td style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#6B7C6B;border-bottom:1px solid #E0D9CE;">Payment Method</td>
                  <td align="right" style="padding:12px 18px;font-family:Arial,sans-serif;font-size:14px;line-height:20px;color:#1B4332;font-weight:bold;border-bottom:1px solid #E0D9CE;">{{params.payment_method}}</td>
                </tr>
                <tr>
                  <td style="padding:14px 18px;font-family:Arial,sans-serif;font-size:15px;line-height:22px;color:#1B4332;font-weight:bold;">Total Amount</td>
                  <td align="right" style="padding:14px 18px;font-family:Georgia,serif;font-size:22px;line-height:26px;color:#2D6A4F;font-weight:bold;">{{params.total_amount}}</td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:12px 24px 8px;font-family:Arial,sans-serif;font-size:14px;line-height:24px;color:#3D5A47;">
