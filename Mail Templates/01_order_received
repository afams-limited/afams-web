        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;max-width:600px;background-color:#FFFFFF;">
          <tr>
            <td align="center" style="background-color:#1B4332;padding:28px 24px 20px;">
              <img src="https://afams.co.ke/assets/images/afams_logo_stacked.png" alt="Afams" width="150" style="display:block;width:150px;max-width:150px;height:auto;border:0;" />
            </td>
          </tr>
          <tr>
            <td align="center" style="background-color:#2D6A4F;padding:12px 24px;font-family:Arial,sans-serif;font-size:13px;line-height:18px;color:#FFFFFF;font-weight:bold;letter-spacing:1px;text-transform:uppercase;">
              Order Confirmed
            </td>
          </tr>
          <tr>
            <td style="padding:32px 24px 12px;font-family:Arial,sans-serif;color:#1B4332;">
