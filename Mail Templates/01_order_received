                <span style="color:#88A897;"> &nbsp;|&nbsp; </span>
                <a href="https://afams.co.ke/privacy-policy.html" style="color:#9FD3B6;text-decoration:none;">Privacy</a>
              </div>
              <div style="font-size:11px;line-height:18px;color:#B8C8BE;">&copy; 2026 Afams Ltd. &middot; <a href="mailto:info@afams.co.ke" style="color:#B8C8BE;text-decoration:none;">info@afams.co.ke</a></div>
