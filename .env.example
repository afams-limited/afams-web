# ── AFAMS Preorder System — Environment Variables ──────────────────────
# Copy this file to .env (never commit .env) and fill in your values.
# Set these as Supabase Secrets: Dashboard → Project → Settings → Edge Functions → Secrets

# ── Paystack ────────────────────────────────────────────────────────────
# Your Paystack Secret Key (server-side only — NEVER expose in frontend code).
# Get from: https://dashboard.paystack.com/#/settings/developer
# Use sk_test_... for development and sk_live_... for production.
PAYSTACK_SECRET_KEY=sk_live_YOUR_PAYSTACK_SECRET_KEY_HERE

# ── Supabase ─────────────────────────────────────────────────────────────
# Your Supabase project URL.
# Get from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase Service Role Key (server-side only — grants full DB access).
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# ⚠️  NEVER expose this in frontend / browser code.
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY_HERE

# Your Supabase Anon Key (used by send-order-email to verify JWT).
SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY_HERE

# ── Brevo (transactional email) ──────────────────────────────────────────
# Get your API key from: https://app.brevo.com/settings/keys/api
# ⚠️  Server-side only — set as a Supabase Secret, NEVER in browser code.
BREVO_API_KEY=xkeysib-YOUR_BREVO_API_KEY_HERE

# Sender identity (must be verified in Brevo)
BREVO_SENDER_EMAIL=orders@afams.co.ke
BREVO_SENDER_NAME=Afams

# Admin email to receive new-order alerts (template #4)
BREVO_ADMIN_EMAIL=iammwombe@gmail.com

# Brevo transactional template IDs.
# Create each template in Brevo Dashboard → Transactional → Templates,
# upload the HTML from the Mail Templates/ folder, then paste the ID here.
BREVO_TEMPLATE_ORDER_RECEIVED=1    # Mail Templates/01_order_received
BREVO_TEMPLATE_PAYMENT_SUCCESS=2   # Mail Templates/02_payment_success.html
BREVO_TEMPLATE_PAYMENT_FAILED=3    # Mail Templates/03_payment_failed.html
BREVO_TEMPLATE_ADMIN_NEW_ORDER=4   # Mail Templates/04_admin_new_order.html
BREVO_TEMPLATE_ORDER_DISPATCHED=5  # Mail Templates/05_order_dispatched.html
BREVO_TEMPLATE_ORDER_DELIVERED=6   # Mail Templates/06_order_delivered.html

# ── Notes ────────────────────────────────────────────────────────────────
# The frontend (index.html / app.js) uses ONLY the Paystack PUBLIC key,
# which is safe to expose in client-side code (set directly in assets/js/app.js).
#
# The admin dashboard uses the Supabase ANON key (also public-safe),
# which you enter once in the browser and is saved in localStorage.
#
# Webhook URL to register in your Paystack dashboard:
#   https://dvquyzzqsnlcassvgdzz.supabase.co/functions/v1/paystack-webhook
