Options -Indexes

# Redirect login.html and dashboard.html to index.html (single entry point)
RewriteEngine On
RewriteBase /admin/
RewriteRule ^(login|dashboard)\.html$ /admin/ [R=301,L]

# Security headers
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "no-referrer"

# No caching for admin HTML (always fresh)
<FilesMatch "\.html$">
  Header set Cache-Control "no-store, no-cache, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>
